# ══════════════════════════════════════════════════════════════════
# Ruai Tech Solutions — Backend Environment Variables
# 1. Copy this file:  cp .env.example .env
# 2. Fill in YOUR values — never commit .env to version control
# 3. Generate JWT_SECRET:  openssl rand -base64 32
# ══════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ── MongoDB Atlas ─────────────────────────────────────────────────
# Create a free cluster at https://cloud.mongodb.com
# Replace <db_user>, <db_password>, and <cluster> with your values
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster>.mongodb.net/ruaitech?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────
# Generate with:  openssl rand -base64 32
JWT_SECRET=<min-32-char-random-string>
JWT_EXPIRE=8h

# ── Super Admin Identity Lock ─────────────────────────────────────
# Must match the email used when seeding the Super Admin account
SUPER_ADMIN_EMAIL=codeofthoth@outlook.com
CLIENT_URL=http://localhost:3000

# ── M-Pesa Daraja (Safaricom) ─────────────────────────────────────
# Register at https://developer.safaricom.co.ke
# For sandbox testing: use sandbox credentials from the developer portal
MPESA_ENV=sandbox
# Set to "production" only once you are ready to take real customer payments.
# Controls which Daraja host is used (middleware/mpesa.js + server.js CSP) —
# previously this had no effect because both were hardcoded to sandbox.
MPESA_CONSUMER_KEY=<your_consumer_key>
MPESA_CONSUMER_SECRET=<your_consumer_secret>
MPESA_SHORTCODE=<your_shortcode>
MPESA_PASSKEY=<your_passkey>
MPESA_CALLBACK_URL=https://<your-domain>/api/payments/mpesa/callback

# ── Africa's Talking (SMS + USSD) ─────────────────────────────────
# Register at https://account.africastalking.com
# Use username 'sandbox' and the sandbox API key for testing
AT_USERNAME=sandbox
AT_API_KEY=<your_africastalking_api_key>
AT_SENDER_ID=RuaiTech
# Optional — only needed if you've activated the WhatsApp product in your
# Africa's Talking dashboard. Leave blank to keep every notification on SMS
# (config/africastalking.js falls back automatically if this is unset).
AT_WHATSAPP_SENDER_ID=<your_whatsapp_sender_phone_number_id>

# ── Cloudinary (File Storage) ─────────────────────────────────────
# Register at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=<your_cloud_name>
CLOUDINARY_API_KEY=<your_api_key>
CLOUDINARY_API_SECRET=<your_api_secret>

# ── Email / SMTP ──────────────────────────────────────────────────
# For Gmail: enable 2FA, then create an App Password at
# https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=<your_email@gmail.com>
EMAIL_PASS=<your_gmail_app_password>

# ── Seed Script Credentials ───────────────────────────────────────
# Used ONLY by:  node seed.js
# Set strong unique passwords before running the seed script.
# These values are never used at runtime — only during initial DB setup.
SEED_SUPER_ADMIN_PASSWORD=<strong-unique-password>
SEED_ADMIN_PASSWORD=<strong-unique-password>
SEED_ADMIN_EMAIL=admin@ruaitechsolutions.co.ke
